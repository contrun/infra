--- wstunnel@.container
[Unit]
Description=wstunnel

[Container]
Image=docker.io/contrun/wstunnel:latest
ReadOnly=true
Network=host
Exec=$WSTUNNEL_COMMAND

[Service]
Type=notify
TimeoutStopSec=5s
LimitNOFILE=1048576
PrivateTmp=true
NoNewPrivileges=true
ProtectHome=true
ProtectSystem=full
AmbientCapabilities=CAP_NET_BIND_SERVICE
EnvironmentFile=/etc/wstunnel/%i.env

[Install]
WantedBy=default.target

