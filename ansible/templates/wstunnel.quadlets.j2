--- wstunnel-{{ idx }}.container
[Unit]
Description=wstunnel

[Container]
Image=docker.io/contrun/wstunnel:latest
ReadOnly=true
Network=host
Exec={{ wstunnel_arguments }}

[Service]
Type=notify
TimeoutStopSec=5s
LimitNOFILE=1048576
PrivateTmp=true
NoNewPrivileges=true
ProtectHome=true
ProtectSystem=full
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=default.target

