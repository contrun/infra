[Unit]
Description=rclone
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
DynamicUser=yes
User=rclone
Group=rclone
StateDirectory=rclone
CacheDirectory=rclone
{% if rclone_config_url is defined -%}
ExecStartPre={{ rclone_executable }} copyurl {{ rclone_config_url }} "%S/rclone/rclone.conf"
{% endif -%}
{% if rclone_htpasswd_url is defined -%}
ExecStartPre={{ rclone_executable }} copyurl {{ rclone_htpasswd_url }} "%S/rclone/rclone.htpasswd"
{% endif -%}
ExecStart={{ rclone_executable }} {{ rclone_arguments | default("rcd --rc-web-gui --rc-web-gui-no-open-browser" + (" --rc-htpasswd %S/rclone/rclone.htpasswd" if rclone_htpasswd_url is defined else "")) }}
TimeoutStopSec=5s
LimitNOFILE=1048576
PrivateTmp=true
NoNewPrivileges=true
PrivateDevices=true
ProtectHome=true
ProtectSystem=full
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
Environment=RCLONE_CONFIG=%S/rclone/rclone.conf
Environment=RCLONE_CACHE_DIR=%C/rclone

[Install]
WantedBy=multi-user.target
